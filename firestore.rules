
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------------
    // Funciones de Ayuda (Helpers)
    // ---------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Función Admin robusta que evita recursión
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isCourseInstructor(instructorId) {
      return isSignedIn() && request.auth.uid == instructorId;
    }

    // ---------------------------------------------------------------------
    // Colecciones de Usuario
    // ---------------------------------------------------------------------

    match /users/{userId} {
      allow create: if isOwner(userId);
      allow get: if isOwner(userId) || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow list: if isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update: if isOwner(userId) || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ---------------------------------------------------------------------
    // Contenido Educativo (Jerárquico)
    // ---------------------------------------------------------------------

    match /courses/{courseId} {
      // Los cursos son legibles por todos (metadatos)
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isCourseInstructor(resource.data.instructorId);

      match /modules/{moduleId} {
        allow read: if true;
        allow write: if isAdmin() || isCourseInstructor(get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId);

        match /lessons/{lessonId} {
            allow read: if true;
            allow write: if isAdmin() || isCourseInstructor(get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId);

            match /resources/{resourceId} {
                allow read: if true;
                allow write: if isAdmin() || isCourseInstructor(get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId);
            }
        }
      }
    }
    
    // ---------------------------------------------------------------------
    // Otras colecciones
    // ---------------------------------------------------------------------

    match /coding_challenges/{id} { allow read: if true; allow write: if isAdmin(); }
    match /users/{userId}/user_progress/{id} { allow read, write: if isOwner(userId) || isAdmin(); }
    match /careers/{id} { allow read: if true; allow write: if isAdmin(); }
    match /technology_trends/{id} { allow read: if true; allow write: if isAdmin(); }
    match /code_review_highlights/{id} { allow read: if true; allow write: if isAdmin(); }
    match /subscriptionPlans/{id} { allow read: if true; allow write: if isAdmin(); }
  }
}
