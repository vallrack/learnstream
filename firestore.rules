
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------------
    // Funciones de Ayuda (Helpers)
    // ---------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isCourseInstructor(instructorId) {
      return isSignedIn() && request.auth.uid == instructorId;
    }

    // ✅ Verifica si el usuario existe y tiene el rol 'admin'
    function isAdmin() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && exists(userPath) && get(userPath).data.role == 'admin';
    }

    function isParentCoursePublished(courseId) {
      let coursePath = /databases/$(database)/documents/courses/$(courseId);
      return exists(coursePath) && get(coursePath).data.isPublished == true;
    }
    
    // ---------------------------------------------------------------------
    // REGLA CRÍTICA: Collection Group (Lecciones)
    // ---------------------------------------------------------------------
    match /{path=**}/lessons/{lessonId} {
      allow list: if isSignedIn();
      allow get: if isAdmin() || (resource.data.isPublished == true);
    }

    // ---------------------------------------------------------------------
    // Colecciones de Usuario
    // ---------------------------------------------------------------------

    match /users/{userId} {
      allow create: if isOwner(userId);
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if false; 
    }

    match /user_profiles/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }
    
    match /instructors/{instructorId} {
      allow read: if true;
      allow write: if isOwner(instructorId) || isAdmin();
    }

    // ---------------------------------------------------------------------
    // Contenido Educativo (Cursos, Módulos, Lecciones, Recursos)
    // ---------------------------------------------------------------------

    match /courses/{courseId} {
      allow get: if (resource.data.isPublished == true) || (isSignedIn() && (isCourseInstructor(resource.data.instructorId) || isAdmin()));
      allow list: if true; 
      allow create: if (isSignedIn() && isCourseInstructor(request.resource.data.instructorId)) || isAdmin();
      allow update, delete: if isCourseInstructor(resource.data.instructorId) || isAdmin();

      match /modules/{moduleId} {
        allow read: if isAdmin() || isParentCoursePublished(courseId) || (isSignedIn() && isCourseInstructor(get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId));
        allow write: if isAdmin() || (isSignedIn() && isCourseInstructor(get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId));

        match /lessons/{lessonId} {
            allow read: if isAdmin() || isParentCoursePublished(courseId) || (isSignedIn() && isCourseInstructor(get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId));
            allow write: if isAdmin() || (isSignedIn() && isCourseInstructor(get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId));

            match /resources/{resourceId} {
                allow read: if isAdmin() || isParentCoursePublished(courseId) || (isSignedIn() && isCourseInstructor(get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId));
                allow write: if isAdmin() || (isSignedIn() && isCourseInstructor(get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId));
            }
        }
      }
    }
    
    match /coding_challenges/{challengeId} { 
      allow read: if true; 
      allow create: if isSignedIn() && request.resource.data.instructorId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.instructorId == request.auth.uid || isAdmin());
    }

    // ---------------------------------------------------------------------
    // Actividad y Progreso
    // ---------------------------------------------------------------------

    match /users/{userId}/user_progress/{id} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /student_error_logs/{id} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || (exists(/databases/$(database)/documents/student_error_logs/$(id)) && isOwner(get(/databases/$(database)/documents/student_error_logs/$(id)).data.userId));
    }

    match /careers/{id} { allow read: if true; allow write: if isAdmin(); }
    match /technology_trends/{id} { allow read: if true; allow write: if isAdmin(); }
    match /code_review_highlights/{id} { allow read: if true; allow write: if isAdmin(); }
  }
}
